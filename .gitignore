# Python cache and compiled files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment variables and credentials
.env
.env.*
!.env.example

# Streamlit secrets
.streamlit/secrets.toml

# Test and type-check caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# IDE settings
.vscode/
.idea/

# Operating-system files
.DS_Store
Thumbs.db
desktop.ini

# Logs and temporary files
*.log
*.tmp
*.temp
~$*

# Claude Code project settings (dev tool, not application code)
.claude/

# Streamlit stdout / stderr capture files created during development
se*.txt
so*.txt
